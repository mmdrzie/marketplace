{
  "name": "marketplace",
  "private": true,
  "workspaces": [
    "backend",
    "packages/*"
  ],
  "scripts": {
    "dev:backend": "npm run dev -w backend",
    "dev:frontend": "cd nextjs-frontend && next dev",
    "dev:all": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "build:backend": "npm run build -w backend",
    "build:frontend": "npm run build -w nextjs-frontend",
    "test:backend": "npm test -w backend",
    "test:frontend": "npm test -w nextjs-frontend",
    "test:all": "npm run test:backend && npm run test:frontend",
    "lint:backend": "npm run lint -w backend",
    "lint:frontend": "npm run lint -w nextjs-frontend",
    "typecheck:backend": "npm run typecheck -w backend",
    "typecheck:frontend": "npm run typecheck -w nextjs-frontend"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
