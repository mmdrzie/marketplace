# ── App ──
NODE_ENV=development
PORT=4000
API_PREFIX=/api/v1
FRONTEND_URL=http://localhost:3000

# ── Database ──
DATABASE_URL=postgres://marketplace:marketplace_pass@localhost:5432/marketplace
DB_POOL_MIN=2
DB_POOL_MAX=10

# ── JWT ──
JWT_SECRET=change-me-to-a-64-char-random-string-in-production
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# ── Email ──
EMAIL_PROVIDER=console
# EMAIL_PROVIDER=smtp
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# EMAIL_FROM=noreply@marketplace.com

# ── SMS ──
SMS_PROVIDER=console
# SMS_PROVIDER=kavenegar
# KAVENEGAR_API_KEY=
# KAVENEGAR_SENDER=

# ── Storage ──
STORAGE_PROVIDER=local
# STORAGE_PROVIDER=s3
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_BUCKET=marketplace-images
# S3_ENDPOINT=
# S3_REGION=ir-thr-at1

# ── Payment ──
PAYMENT_PROVIDER=noop
# PAYMENT_PROVIDER=zarinpal
# ZARINPAL_MERCHANT_ID=
# ZARINPAL_CALLBACK_URL=http://localhost:4000/api/v1/payments/verify

# ── Rate Limits ──
GLOBAL_RATE_LIMIT=100
GLOBAL_RATE_WINDOW=60
LOGIN_RATE_LIMIT=5
LOGIN_RATE_WINDOW=900
REGISTER_RATE_LIMIT=5
REGISTER_RATE_WINDOW=3600
OTP_SEND_RATE_LIMIT=3
OTP_SEND_RATE_WINDOW=3600
OTP_VERIFY_RATE_LIMIT=10
OTP_VERIFY_RATE_WINDOW=900
FORGOT_RATE_LIMIT=3
FORGOT_RATE_WINDOW=3600
VERIFY_EMAIL_RATE_LIMIT=5
VERIFY_EMAIL_RATE_WINDOW=86400
PUBLISH_LISTING_RATE_LIMIT=10
PUBLISH_LISTING_RATE_WINDOW=86400
CONVERSATION_RATE_LIMIT=30
CONVERSATION_RATE_WINDOW=3600
MESSAGE_RATE_LIMIT=60
MESSAGE_RATE_WINDOW=60
